{
  "name": "@sigilry/dapp",
  "version": "2.0.0-next.2",
  "description": "Chain/transport-agnostic dApp infrastructure - RPC client/server and transports",
  "keywords": [
    "blockchain",
    "dapp",
    "json-rpc",
    "rpc",
    "transport",
    "typescript",
    "wallet",
    "web3",
    "zod"
  ],
  "homepage": "https://sigilry.org",
  "bugs": {
    "url": "https://github.com/sigilry/sigilry/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilry/sigilry.git",
    "directory": "packages/dapp"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./browser-globals": {
      "types": "./dist/src/browser-globals.d.ts",
      "default": "./dist/src/browser-globals.js"
    },
    "./messages": {
      "types": "./dist/src/messages/index.d.ts",
      "default": "./dist/src/messages/index.js"
    },
    "./messages/runtime-schemas": {
      "types": "./dist/src/messages/runtime-schemas.d.ts",
      "default": "./dist/src/messages/runtime-schemas.js"
    },
    "./rpc": {
      "types": "./dist/src/rpc/index.d.ts",
      "default": "./dist/src/rpc/index.js"
    },
    "./schemas": {
      "types": "./dist/src/generated/schemas.d.ts",
      "default": "./dist/src/generated/schemas.js"
    },
    "./provider": {
      "types": "./dist/src/provider/index.d.ts",
      "default": "./dist/src/provider/index.js"
    },
    "./transport": {
      "types": "./dist/src/transport/index.d.ts",
      "default": "./dist/src/transport/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "codegen": "bun scripts/codegen.ts",
    "build": "bun run codegen && zshy",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "json-schema-to-zod": "^2.7.0",
    "typescript": "^5.8.3",
    "zshy": "^0.7.0"
  },
  "zshy": {
    "exports": {
      ".": "./src/index.ts",
      "./browser-globals": "./src/browser-globals.ts",
      "./messages": "./src/messages/index.ts",
      "./messages/runtime-schemas": "./src/messages/runtime-schemas.ts",
      "./rpc": "./src/rpc/index.ts",
      "./schemas": "./src/generated/schemas.ts",
      "./provider": "./src/provider/index.ts",
      "./transport": "./src/transport/index.ts"
    },
    "cjs": false
  }
}
