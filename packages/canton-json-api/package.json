{
  "name": "@sigilry/canton-json-api",
  "version": "1.0.2-next.0",
  "description": "Generated TypeScript types for Canton JSON API v2",
  "keywords": [
    "canton",
    "json-api",
    "openapi",
    "typescript"
  ],
  "homepage": "https://sigilry.org",
  "bugs": {
    "url": "https://github.com/sigilry/sigilry/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilry/sigilry.git",
    "directory": "packages/canton-json-api"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "fetch": "bun scripts/fetch-canton.ts",
    "codegen": "openapi-ts",
    "codegen:check": "bun run codegen && git diff --exit-code -- src/generated/types.gen.ts src/generated/zod.gen.ts src/generated/transformers.gen.ts && test -z \"$(git ls-files --others --exclude-standard -- src/generated/types.gen.ts src/generated/zod.gen.ts src/generated/transformers.gen.ts)\"",
    "regen": "bun run fetch && bun run codegen",
    "build": "zshy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.92.4",
    "@types/bun": "^1.3.4",
    "typescript": "^5.8.3",
    "zshy": "^0.7.0"
  },
  "zshy": {
    "exports": {
      ".": "./src/index.ts"
    },
    "cjs": false
  }
}
