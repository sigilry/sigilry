---
export const prerender = true;
const base = import.meta.env.BASE_URL ?? '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found</title>
  </head>
  <body>
    <main style="max-width: 720px; margin: 4rem auto; padding: 0 1.5rem; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif;">
      <h1>Page not found</h1>
      <p>The page you are looking for does not exist.</p>
      <p><a href={base}>Back to docs home</a></p>
    </main>
  </body>
</html>
